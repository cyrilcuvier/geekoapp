[Unit]
Description=L'Oracle de Geeko (legacy fortune service)
After=network.target

[Service]
Type=simple
Environment=GEEKO_ORACLE_FLAG_PATH=/etc/geeko-oracle/patched
ExecStart=/opt/geeko-oracle/venv/bin/uvicorn oracle_service.main:app --host 0.0.0.0 --port 9000
WorkingDirectory=/opt/geeko-oracle
Restart=on-failure

[Install]
WantedBy=multi-user.target
